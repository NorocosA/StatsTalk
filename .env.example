# ═══════════════════════════════════════════
# StatsTalk 配置文件
# ═══════════════════════════════════════════
# 复制此文件为 .env:  copy .env.example .env
# 或运行:  setup.bat  (一键安装)
#
# [必填] = 必须配置才能使用真实 LLM
# [可选] = 有默认值，可不修改
# [Demo] = Demo 模式专用，LLM_MOCK=true 时无需配置
# ═══════════════════════════════════════════

# ── SPSS 路径 [可选] ──────────────────────────
SPSS_PATH=C:\Program Files\IBM\SPSS\Statistics\26\stats.exe
SPSS_PYTHON_PATH=C:\Program Files\IBM\SPSS\Statistics\26\Python3\python.exe
SPSS_EXEC_MODE=python

# ── LLM 配置 ─────────────────────────────────
# LLM_API_KEY [必填] — 真实 LLM 分析需要 API Key
LLM_ENDPOINT=https://opencode.ai/zen/go/v1/chat/completions
LLM_API_KEY=your-api-key-here
LLM_MODEL=deepseek-v4-flash

# ── Token 控制 [可选] ─────────────────────────
LLM_MAX_INPUT_TOKENS=4000
LLM_MAX_OUTPUT_TOKENS=2000
LLM_MAX_HISTORY_ROUNDS=3

# ── 执行器 [可选] ─────────────────────────────
SPSS_EXECUTION_TIMEOUT=120
STATS_BACKEND=spss         # "spss" | "python" | "auto"

# ── 调试 [可选] ───────────────────────────────
LLM_CALL_LOG=false
LLM_MOCK=false             # [Demo] true = 无需 API Key 即可试用
DEBUG=false                # true = 显示详细日志
